

<section class="ugc-videos ugc-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="ugc__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="ugc__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="ugc__wrap">
      <button class="ugc__arrow ugc__arrow--prev" type="button" aria-label="Previous">‹</button>

      <div class="ugc__scroller" data-ugc-scroller>
        {% for block in section.blocks %}
          {% assign poster = block.settings.poster %}
          {% assign has_shopify_video = false %}
          {% if block.settings.shopify_video != blank %}
            {% assign has_shopify_video = true %}
          {% endif %}

          <button
            class="ugc__card"
            type="button"
            data-ugc-open
            data-kind="{% if has_shopify_video %}shopify{% else %}url{% endif %}"
            data-url="{{ block.settings.video_url | escape }}"
            data-poster="{% if poster != blank %}{{ poster | image_url: width: 1600 }}{% endif %}"
            aria-label="Open video"
            {{ block.shopify_attributes }}
          >
            <div class="ugc__media">
              {% if poster != blank %}
                <img
                  class="ugc__poster"
                  src="{{ poster | image_url: width: 900 }}"
                  alt="{{ block.settings.alt | escape }}"
                  loading="lazy"
                >
              {% else %}
                <div class="ugc__poster ugc__poster--placeholder"></div>
              {% endif %}

              <span class="ugc__play" aria-hidden="true">▶</span>

              {%- comment -%}
                Hidden data container for Shopify video (we will read it in JS)
              {%- endcomment -%}
              {% if has_shopify_video %}
                <div class="ugc__video-data" hidden>
                  {{ block.settings.shopify_video | video_tag: preload: 'metadata' }}
                </div>
              {% endif %}
            </div>

            {% if block.settings.caption != blank %}
              <div class="ugc__caption">{{ block.settings.caption }}</div>
            {% endif %}
          </button>
        {% endfor %}
      </div>

      <button class="ugc__arrow ugc__arrow--next" type="button" aria-label="Next">›</button>
    </div>
  </div>

  <!-- Modal -->
  <div class="ugc__modal" data-ugc-modal hidden>
    <div class="ugc__backdrop" data-ugc-close></div>

    <div class="ugc__dialog" role="dialog" aria-modal="true" aria-label="Video preview">
      <button class="ugc__close" type="button" data-ugc-close aria-label="Close">✕</button>
      <div class="ugc__modal-media"></div>
    </div>
  </div>
</section>

<style>
  .ugc-{{ section.id }}{
    --tile-w: {{ section.settings.tile_width }}px;
    --tile-h: {{ section.settings.tile_height }}px;
    --radius: {{ section.settings.radius }}px;
    --gap: 22px;
  }

  .ugc-videos { padding: 48px 0 28px; }

  .ugc__heading{
    margin: 0 0 6px;
    text-align: center;
    letter-spacing: .18em;
    text-transform: uppercase;
  }
  .ugc__subheading{
    margin: 0 0 24px;
    text-align: center;
    opacity: .85;
  }

  .ugc__wrap{
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
  }

  .ugc__arrow{
    border: 0;
    background: transparent;
    font-size: 44px;
    line-height: 1;
    cursor: pointer;
    opacity: .7;
    padding: 8px 10px;
    user-select: none;
  }
  .ugc__arrow:hover{ opacity: 1; }

  .ugc__scroller{
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: var(--tile-w);
    gap: var(--gap);
    overflow-x: auto;
    padding: 8px 4px 14px;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
  .ugc__scroller::-webkit-scrollbar{ height: 8px; }
  .ugc__scroller::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.15); border-radius: 999px; }

  .ugc__card{
    scroll-snap-align: start;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
    text-align: left;
  }

  .ugc__media{
    position: relative;
    width: var(--tile-w);
    height: var(--tile-h);
    border-radius: var(--radius);
    overflow: hidden;
    background: rgba(0,0,0,.06);
    box-shadow: 0 10px 24px rgba(0,0,0,.12);
    transition: transform .18s ease, box-shadow .18s ease;
  }

  .ugc__card:hover .ugc__media{
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(0,0,0,.16);
  }

  .ugc__poster{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ugc__poster--placeholder{
    width: 100%;
    height: 100%;
    background: linear-gradient(120deg, rgba(0,0,0,.06), rgba(0,0,0,.02));
  }

  .ugc__play{
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 28px;
    width: 64px;
    height: 64px;
    margin: auto;
    border-radius: 999px;
    background: rgba(0,0,0,.55);
    color: #fff;
    box-shadow: 0 10px 24px rgba(0,0,0,.28);
  }

  .ugc__caption{
    margin-top: 10px;
    font-size: 14px;
    opacity: .85;
    max-width: var(--tile-w);
  }

  /* Modal */
  .ugc__modal[hidden]{ display:none; }
  .ugc__modal{
    position: fixed;
    inset: 0;
    z-index: 9999;
  }
  .ugc__backdrop{
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.55);
  }
  .ugc__dialog{
    position: relative;
    width: min(980px, calc(100% - 32px));
    margin: 32px auto;
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,.35);
  }
  .ugc__close{
    position: absolute;
    top: 10px;
    right: 10px;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 0;
    background: rgba(0,0,0,.6);
    color: #fff;
    cursor: pointer;
    z-index: 2;
  }

  .ugc__modal-media{
    background: #000;
    aspect-ratio: 16 / 9;
  }
  .ugc__modal-media video,
  .ugc__modal-media iframe{
    width: 100%;
    height: 100%;
    display: block;
    background: #000;
  }

  @media (max-width: 989px){
    .ugc-{{ section.id }}{ --tile-w: 220px; --tile-h: 320px; }
    .ugc__arrow{ display:none; }
    .ugc__dialog{ margin: 18px auto; }
    .ugc__modal-media{ aspect-ratio: 9 / 16; }
  }
</style>

<script>
  (function () {
    const root = document.querySelector('.ugc-{{ section.id }}');
    if (!root) return;

    const scroller = root.querySelector('[data-ugc-scroller]');
    const prev = root.querySelector('.ugc__arrow--prev');
    const next = root.querySelector('.ugc__arrow--next');

    const modal = root.querySelector('[data-ugc-modal]');
    const modalMedia = root.querySelector('.ugc__modal-media');

    function scrollByCard(dir) {
      const card = scroller.querySelector('.ugc__media');
      const w = card ? card.getBoundingClientRect().width : 300;
      scroller.scrollBy({ left: dir * (w + 22), behavior: 'smooth' });
    }

    if (prev) prev.addEventListener('click', () => scrollByCard(-1));
    if (next) next.addEventListener('click', () => scrollByCard(1));

    function openModalWithVideoEl(videoEl) {
      modalMedia.innerHTML = '';
      videoEl.removeAttribute('width');
      videoEl.removeAttribute('height');

      // Ensure modal playback
      videoEl.setAttribute('controls', 'controls');
      videoEl.setAttribute('playsinline', 'playsinline');
      videoEl.style.width = '100%';
      videoEl.style.height = '100%';

      modalMedia.appendChild(videoEl);
      modal.hidden = false;
      document.body.style.overflow = 'hidden';

      videoEl.play().catch(() => {});
    }

    function openModalFromUrl(url, poster) {
      modalMedia.innerHTML = '';

      const v = document.createElement('video');
      v.setAttribute('controls', 'controls');
      v.setAttribute('playsinline', 'playsinline');
      v.setAttribute('preload', 'metadata');
      if (poster) v.poster = poster;

      v.src = url;
      modalMedia.appendChild(v);

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      v.play().catch(() => {});
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      modalMedia.innerHTML = '';
    }

    root.querySelectorAll('[data-ugc-open]').forEach(btn => {
      btn.addEventListener('click', () => {
        const kind = btn.getAttribute('data-kind');
        const poster = btn.getAttribute('data-poster') || '';

        if (kind === 'shopify') {
          const container = btn.querySelector('.ugc__video-data');
          if (!container) return;
          const originalVideo = container.querySelector('video');
          if (!originalVideo) return;
          const clone = originalVideo.cloneNode(true);
          openModalWithVideoEl(clone);
          return;
        }

        const url = btn.getAttribute('data-url');
        if (!url) return;
        openModalFromUrl(url, poster);
      });
    });

    root.querySelectorAll('[data-ugc-close]').forEach(el => {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  })();
</script>

{% schema %}
{
  "name": "UGC Video Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "SEE ME IN ACTION."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtitle",
      "default": "Scroll for more, click to watch."
    },
    {
      "type": "range",
      "id": "tile_width",
      "label": "Tile width (desktop)",
      "min": 220,
      "max": 420,
      "step": 10,
      "default": 280,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "tile_height",
      "label": "Tile height (desktop)",
      "min": 260,
      "max": 520,
      "step": 10,
      "default": 380,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Corner radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 18,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video tile",
      "settings": [
        {
          "type": "video",
          "id": "shopify_video",
          "label": "Upload video (Shopify hosted)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Or paste YouTube/Vimeo URL",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image (thumbnail)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)",
          "default": "video caption goes here"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Poster alt text",
          "default": "Video thumbnail"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Video Carousel",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
