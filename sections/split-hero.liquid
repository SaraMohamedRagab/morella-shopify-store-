{% comment %}
  Split Hero (Text Left / Image Right)
  - Upload image in the editor (image_picker)
  - Optional: switch image to left on desktop
{% endcomment %}

<section class="split-hero split-hero--{{ section.id }}">
  <div class="split-hero__inner page-width">
    <div class="split-hero__grid {% if section.settings.image_left %}is-image-left{% endif %}">
      
      <div class="split-hero__content">
        {% if section.settings.kicker != blank %}
          <p class="split-hero__kicker">{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="split-hero__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="split-hero__text">{{ section.settings.text }}</div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a class="split-hero__btn" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      <div class="split-hero__media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'split-hero__img', loading: 'lazy', alt: section.settings.image_alt | escape }}
        {% else %}
          <div class="split-hero__placeholder">
            Add an image in the section settings →
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<style>
  .split-hero--{{ section.id }}{
    background: {{ section.settings.bg }};
    padding: clamp(28px, 4vw, 64px) 0;
  }

  .split-hero--{{ section.id }} .split-hero__grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(18px, 3vw, 40px);
    align-items: center;
  }

  .split-hero--{{ section.id }} .split-hero__grid.is-image-left{
    direction: rtl;
  }
  .split-hero--{{ section.id }} .split-hero__grid.is-image-left > *{
    direction: ltr;
  }

  .split-hero--{{ section.id }} .split-hero__content{
    text-align: center;
    max-width: 620px;
    margin: 0 auto;
  }

  .split-hero--{{ section.id }} .split-hero__kicker{
    margin: 0 0 10px;
    color: {{ section.settings.kicker_color }};
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-size: 12px;
  }

  .split-hero--{{ section.id }} .split-hero__heading{
    margin: 0 0 16px;
    color: {{ section.settings.heading_color }};
    font-size: clamp(26px, 3vw, 44px);
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .split-hero--{{ section.id }} .split-hero__text{
    color: {{ section.settings.text_color }};
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 18px;
  }

  .split-hero--{{ section.id }} .split-hero__btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 26px;
    border-radius: 10px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    text-decoration: none;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-size: 13px;
    transition: transform .15s ease, filter .15s ease;
  }
  .split-hero--{{ section.id }} .split-hero__btn:hover{
    transform: translateY(-1px);
    filter: brightness(0.97);
  }

  .split-hero--{{ section.id }} .split-hero__media{
    border-radius: 18px;
    overflow: hidden;
    background: rgba(0,0,0,0.03);
    min-height: 280px;
  }

  .split-hero--{{ section.id }} .split-hero__img{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 16 / 10;
  }

  .split-hero--{{ section.id }} .split-hero__placeholder{
    height: 100%;
    min-height: 280px;
    display: grid;
    place-items: center;
    color: rgba(0,0,0,0.55);
    font-size: 14px;
    padding: 20px;
    text-align: center;
  }

  @media (max-width: 900px){
    .split-hero--{{ section.id }} .split-hero__grid{
      grid-template-columns: 1fr;
    }
    .split-hero--{{ section.id }} .split-hero__content{
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "Split Hero (Text + Image)",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Morella product"
    },
    {
      "type": "checkbox",
      "id": "image_left",
      "label": "Show image on left (desktop)",
      "default": false
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Small label (optional)",
      "default": "Body care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The scrub that made me famous."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text (optional)",
      "default": "<p>Soft, smooth, and glowing skin — in minutes.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background color",
      "default": "#f6d6dc"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2b1c22"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3d2a33"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker color",
      "default": "#6a4a57"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background",
      "default": "#2b1c22"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    { "name": "Split Hero (Text + Image)" }
  ]
}
{% endschema %}
